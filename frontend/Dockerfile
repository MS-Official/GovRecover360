FROM node:20-alpine AS build

WORKDIR /app

ARG VITE_API_BASE_URL=/api
ARG VITE_AUTH_MODE=mock
ARG VITE_ASGARDEO_CLIENT_ID=
ARG VITE_ASGARDEO_BASE_URL=
ARG VITE_ASGARDEO_SIGN_IN_REDIRECT_URL=http://localhost:3000/callback
ARG VITE_ASGARDEO_SIGN_OUT_REDIRECT_URL=http://localhost:3000/login
ARG VITE_ASGARDEO_SCOPES="openid profile email groups"
ARG VITE_ASGARDEO_SIGN_UP_URL=

ENV VITE_API_BASE_URL=$VITE_API_BASE_URL
ENV VITE_AUTH_MODE=$VITE_AUTH_MODE
ENV VITE_ASGARDEO_CLIENT_ID=$VITE_ASGARDEO_CLIENT_ID
ENV VITE_ASGARDEO_BASE_URL=$VITE_ASGARDEO_BASE_URL
ENV VITE_ASGARDEO_SIGN_IN_REDIRECT_URL=$VITE_ASGARDEO_SIGN_IN_REDIRECT_URL
ENV VITE_ASGARDEO_SIGN_OUT_REDIRECT_URL=$VITE_ASGARDEO_SIGN_OUT_REDIRECT_URL
ENV VITE_ASGARDEO_SCOPES=$VITE_ASGARDEO_SCOPES
ENV VITE_ASGARDEO_SIGN_UP_URL=$VITE_ASGARDEO_SIGN_UP_URL

COPY package.json ./
RUN npm install

COPY . .
RUN npm run build

FROM nginx:alpine
COPY --from=build /app/dist /usr/share/nginx/html
COPY --from=build /app/nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 3000

CMD ["nginx", "-g", "daemon off;"]
