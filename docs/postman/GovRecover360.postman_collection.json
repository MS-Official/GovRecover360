    {
      "name": "Disasters",
      "description": "Disaster event management endpoints",
      "item": [
        {
          "name": "List Disasters",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token_admin}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/disasters",
              "host": ["{{base_url}}"],
              "path": ["api", "disasters"]
            },
            "description": "List all disaster events. Authenticated users can access this endpoint."
          },
          "response": []
        },
        {
          "name": "Create Disaster",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token_admin}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Northeast Monsoon Floods 2025\",\n  \"description\": \"Severe flooding in Northern and Eastern provinces due to monsoon rains\",\n  \"disaster_type\": \"FLOOD\",\n  \"severity\": \"SEVERE\",\n  \"status\": \"ACTIVE\",\n  \"start_date\": \"2025-01-15T00:00:00Z\",\n  \"end_date\": \"2025-02-28T00:00:00Z\",\n  \"affected_districts\": [\"Jaffna\", \"Trincomalee\", \"Batticaloa\", \"Ampara\"]\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/disasters",
              "host": ["{{base_url}}"],
              "path": ["api", "disasters"]
            },
            "description": "Create a new disaster event. Requires Admin, Disaster Manager, or Program Manager role."
          },
          "response": []
        },
        {
          "name": "Get Disaster by ID",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token_admin}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/disasters/{{disaster_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "disasters", "{{disaster_id}}"]
            },
            "description": "Get details of a specific disaster event by ID."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Households",
      "description": "Household registration and management endpoints",
      "item": [
        {
          "name": "Register Household",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token_field}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"head_full_name\": \"Saman Weerasinghe\",\n  \"head_nic\": \"901234567V\",\n  \"head_phone\": \"071-2345678\",\n  \"district\": \"Galle\",\n  \"ds_division\": \"Divisional Secretariat A\",\n  \"gn_division\": \"Grama Niladhari 01\",\n  \"address\": \"123, Main Street, Galle\",\n  \"family_size\": 5,\n  \"damage_level\": \"SEVERE\",\n  \"damage_description\": \"House severely damaged by flood waters. Roof collapsed, walls damaged.\",\n  \"latitude\": 6.0367,\n  \"longitude\": 80.217,\n  \"disaster_event_id\": null\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/households/register",
              "host": ["{{base_url}}"],
              "path": ["api", "households", "register"]
            },
            "description": "Register a new affected household. Requires citizen:create permission (Admin, Field Officer, Citizen)."
          },
          "response": []
        },
        {
          "name": "List Households",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData && jsonData.length > 0) {",
                  "  pm.collectionVariables.set('household_id', jsonData[0].id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token_admin}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/households",
              "host": ["{{base_url}}"],
              "path": ["api", "households"]
            },
            "description": "List all registered households. Results are filtered by user role."
          },
          "response": []
        },
        {
          "name": "Get Household by ID",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token_admin}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/households/{{household_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "households", "{{household_id}}"]
            },
            "description": "Get details of a specific household by ID."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Verification",
      "description": "Relief application submission, verification, and rejection endpoints",
      "item": [
        {
          "name": "Create Application",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token_field}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"household_id\": \"{{household_id}}\",\n  \"disaster_event_id\": null,\n  \"required_items\": [\"Food Pack\", \"Water Bottle\", \"Tent\", \"Blanket\"]\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/applications",
              "host": ["{{base_url}}"],
              "path": ["api", "applications"]
            },
            "description": "Create a new relief application for a household. Any authenticated user can create an application."
          },
          "response": []
        },
        {
          "name": "List Applications",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData && jsonData.length > 0) {",
                  "  pm.collectionVariables.set('application_id', jsonData[0].id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token_admin}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/applications",
              "host": ["{{base_url}}"],
              "path": ["api", "applications"]
            },
            "description": "List all relief applications. Results are filtered by user role."
          },
          "response": []
        },
        {
          "name": "Submit Application",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token_field}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/applications/{{application_id}}/submit",
              "host": ["{{base_url}}"],
              "path": ["api", "applications", "{{application_id}}", "submit"]
            },
            "description": "Submit a draft application for review. Changes status from DRAFT to SUBMITTED."
          },
          "response": []
        },
        {
          "name": "Verify Application",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token_verifier}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"notes\": \"Identity verified. Documentation complete. Household eligible for relief.\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/applications/{{application_id}}/verify",
              "host": ["{{base_url}}"],
              "path": ["api", "applications", "{{application_id}}", "verify"]
            },
            "description": "Verify a submitted application. Changes status from SUBMITTED to VERIFIED. Requires beneficiary:verify permission."
          },
          "response": []
        },
        {
          "name": "Reject Application",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token_verifier}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"notes\": \"Incomplete documentation. Required: proof of residence and damage assessment report.\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/applications/{{application_id}}/reject",
              "host": ["{{base_url}}"],
              "path": ["api", "applications", "{{application_id}}", "reject"]
            },
            "description": "Reject an application with a reason. Changes status to REJECTED. Requires beneficiary:verify permission."
          },
          "response": []
        }
      ]
    },
