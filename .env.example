# =============================================================================
# GovRecover360 Environment Configuration
# =============================================================================
# Copy this file to .env and adjust values for your environment.
#   cp .env.example .env
#
# NEVER commit the actual .env file to version control.
# =============================================================================

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
# Password for the GovRecover application PostgreSQL database user.
DB_PASSWORD=govrecover@2026

# Full SQLAlchemy/PostgreSQL connection URL for the backend.
# Leave unset for local Docker Postgres, or set this to use Supabase.
# Supabase shared transaction pooler example:
# DATABASE_URL=postgresql://postgres.rudxmttefdvebhmpzvsj:YOUR_URL_ENCODED_PASSWORD@aws-1-ap-northeast-1.pooler.supabase.com:6543/postgres?sslmode=require
DATABASE_URL=

# ---------------------------------------------------------------------------
# Backend (FastAPI)
# ---------------------------------------------------------------------------
# Secret key for JWT token signing and encryption.
# Generate a strong random key for production:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=govrecover-super-secret-key-change-in-production

# Redis connection string for caching and session management.
REDIS_URL=redis://redis:6379/0

# Authentication mode. Use mock for local demo, asgardeo for real OIDC login.
AUTH_MODE=mock

# Backend Asgardeo JWT validation configuration. Do not set client secrets in the SPA.
ASGARDEO_ISSUER=https://api.asgardeo.io/t/geoedge/oauth2/token
ASGARDEO_JWKS_URL=https://api.asgardeo.io/t/geoedge/oauth2/jwks
ASGARDEO_AUDIENCE=
ASGARDEO_CLIENT_ID=your_asgardeo_client_id
ASGARDEO_ORG_NAME=geoedge
ASGARDEO_SIGN_UP_URL=https://api.asgardeo.io/t/geoedge/accountrecoveryendpoint/register.do

# Deployed frontend origin allowed by FastAPI CORS.
FRONTEND_URL=http://localhost:3000

# Choreo User Store API. Copy these from the Choreo endpoint security panel.
CHOREO_USER_SERVICE_URL=https://your-choreo-user-service-invoke-url
CHOREO_SECURITY_HEADER_NAME=your_choreo_security_header_name
CHOREO_SECURITY_HEADER_VALUE=your_choreo_security_header_value
CHOREO_NOTIFIER_API_URL=https://your-choreo-notifier-invoke-url

# OpenG2P beneficiary/social protection demo integration.
# The OpenG2P stack may run separately, for example govaid-connect-openg2p-demo.
OPENG2P_ENABLED=true
OPENG2P_BASE_URL=http://localhost:8070
OPENG2P_API_BASE_URL=http://localhost:8070/api
OPENG2P_DB=openg2p
OPENG2P_USERNAME=admin
OPENG2P_PASSWORD=admin

# ---------------------------------------------------------------------------
# AI / ML Provider
# ---------------------------------------------------------------------------
# Supported values: mock, openai, gemini, minimax
AI_PROVIDER=mock

# API keys for AI providers (leave empty to use the mock provider).
OPENAI_API_KEY=
GEMINI_API_KEY=
MINIMAX_API_KEY=

# Frontend authentication and API configuration.
VITE_AUTH_MODE=mock
VITE_API_BASE_URL=http://localhost/api
VITE_ASGARDEO_CLIENT_ID=your_asgardeo_client_id
VITE_ASGARDEO_BASE_URL=https://api.asgardeo.io/t/geoedge
VITE_ASGARDEO_AUTH_URL=https://accounts.asgardeo.io/t/geoedge
VITE_ASGARDEO_REDIRECT_URI=http://localhost:3000/callback
VITE_ASGARDEO_LOGOUT_REDIRECT_URI=http://localhost:3000/login
VITE_ASGARDEO_SCOPES=openid profile email groups
VITE_ASGARDEO_SIGN_UP_URL=https://api.asgardeo.io/t/geoedge/accountrecoveryendpoint/register.do
VITE_CHOREO_USER_SERVICE_URL=https://your-choreo-user-service-invoke-url

# ---------------------------------------------------------------------------
# Odoo ERP
# ---------------------------------------------------------------------------
# PostgreSQL password for the Odoo database user.
ODOO_DB_PASSWORD=odoo@2026
ODOO_BASE_URL=http://localhost:8069
ODOO_DB=your_odoo_database
ODOO_USERNAME=your_odoo_username
ODOO_PASSWORD=your_odoo_password

# ---------------------------------------------------------------------------
# Apache Superset
# ---------------------------------------------------------------------------
# Secret key for Flask / Superset session signing.
SUPERSET_SECRET_KEY=superset-super-secret-change-me

# Admin password for the Superset admin user (username: admin).
SUPERSET_ADMIN_PASSWORD=admin

# PostgreSQL / SQLAlchemy URI for Superset's own metadata database.
# By default Superset shares the GovRecover PostgreSQL instance.
SUPERSET_DATABASE_URI=postgresql://govrecover:govrecover@2026@postgres:5432/govrecover
