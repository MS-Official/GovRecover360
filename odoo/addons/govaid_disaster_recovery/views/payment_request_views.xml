<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tree View -->
    <record id="view_payment_request_tree" model="ir.ui.view">
        <field name="name">payment.request.tree</field>
        <field name="model">payment.request</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="relief_application_id"/>
                <field name="amount"/>
                <field name="currency"/>
                <field name="payment_type"/>
                <field name="status" decoration-success="status == 'PROCESSED'" decoration-danger="status == 'REJECTED'" decoration-warning="status == 'PENDING'"/>
                <field name="approved_by"/>
                <field name="approved_date"/>
            </tree>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_payment_request_form" model="ir.ui.view">
        <field name="name">payment.request.form</field>
        <field name="model">payment.request</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <field name="status" widget="statusbar" statusbar_visible="PENDING,APPROVED,PROCESSED"/>
                    <button name="action_approve" string="Approve" type="object" states="PENDING" class="btn-success"/>
                    <button name="action_reject" string="Reject" type="object" states="PENDING" class="btn-danger"/>
                    <button name="action_process" string="Mark Processed" type="object" states="APPROVED" class="btn-primary"/>
                    <button name="action_back_to_pending" string="Reset to Pending" type="object" states="APPROVED,REJECTED" confirm="Reset payment request to Pending?" class="btn-default"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="relief_application_id" options="{'no_create': True}"/>
                            <field name="payment_type"/>
                        </group>
                        <group>
                            <field name="amount"/>
                            <field name="currency"/>
                        </group>
                    </group>
                    <group>
                        <group>
                            <field name="approved_by"/>
                            <field name="approved_date"/>
                        </group>
                        <group>
                            <field name="processed_date"/>
                        </group>
                    </group>
                    <field name="notes" nolabel="1" placeholder="Payment notes..."/>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="activity_ids" widget="mail_activity"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_payment_request" model="ir.actions.act_window">
        <field name="name">Payment Requests</field>
        <field name="res_model">payment.request</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Create a Payment Request</p>
            <p>Manage cash, voucher, and bank transfer payments to approved beneficiaries.</p>
        </field>
    </record>
</odoo>
