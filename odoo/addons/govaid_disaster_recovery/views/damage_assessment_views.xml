<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tree View -->
    <record id="view_damage_assessment_tree" model="ir.ui.view">
        <field name="name">damage.assessment.tree</field>
        <field name="model">damage.assessment</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="relief_application_id"/>
                <field name="assessor_id"/>
                <field name="damage_level"/>
                <field name="structural_damage_score"/>
                <field name="content_loss_score"/>
                <field name="casualties"/>
                <field name="injuries"/>
                <field name="assessment_date"/>
            </tree>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_damage_assessment_form" model="ir.ui.view">
        <field name="name">damage.assessment.form</field>
        <field name="model">damage.assessment</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="relief_application_id" options="{'no_create': True}"/>
                            <field name="assessor_id"/>
                            <field name="assessment_date"/>
                        </group>
                        <group>
                            <field name="damage_level"/>
                            <field name="structural_damage_score"/>
                            <field name="content_loss_score"/>
                        </group>
                    </group>
                    <group>
                        <group>
                            <field name="casualties"/>
                            <field name="injuries"/>
                        </group>
                    </group>
                    <field name="assessment_notes" nolabel="1" placeholder="Detailed assessment notes..."/>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="activity_ids" widget="mail_activity"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_damage_assessment" model="ir.actions.act_window">
        <field name="name">Damage Assessments</field>
        <field name="res_model">damage.assessment</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Create a Damage Assessment</p>
            <p>Record detailed property damage assessments for relief applicants.</p>
        </field>
    </record>
</odoo>
