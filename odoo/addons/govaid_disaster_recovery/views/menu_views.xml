<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Top-level App Menu -->
    <menuitem id="menu_govaid_root" name="Disaster Recovery"
              web_icon="govaid_disaster_recovery,static/description/icon.png"
              sequence="10"/>

    <!-- Disaster Events -->
    <menuitem id="menu_govaid_disaster_events" name="Disaster Events"
              parent="menu_govaid_root"
              action="action_disaster_event"
              sequence="10"/>

    <!-- OpenG2P-aligned beneficiary management -->
    <menuitem id="menu_govaid_openg2p_demo" name="OpenG2P-Aligned Demo Module"
              parent="menu_govaid_root"
              sequence="20"/>

    <menuitem id="menu_govaid_g2p_beneficiaries" name="Beneficiary Registry"
              parent="menu_govaid_openg2p_demo"
              action="action_g2p_beneficiary_demo"
              sequence="10"/>

    <menuitem id="menu_govaid_g2p_households" name="Household Registry"
              parent="menu_govaid_openg2p_demo"
              action="action_g2p_household_demo"
              sequence="20"/>

    <menuitem id="menu_govaid_g2p_enrollments" name="Program Enrollments"
              parent="menu_govaid_openg2p_demo"
              action="action_g2p_program_enrollment_demo"
              sequence="30"/>

    <menuitem id="menu_govaid_g2p_entitlements" name="Entitlements"
              parent="menu_govaid_openg2p_demo"
              action="action_g2p_entitlement_demo"
              sequence="40"/>

    <!-- Relief Operations -->
    <menuitem id="menu_govaid_relief" name="Relief Operations"
              parent="menu_govaid_root"
              sequence="30"/>

    <menuitem id="menu_govaid_relief_applications" name="Relief Applications"
              parent="menu_govaid_relief"
              action="action_relief_application"
              sequence="10"/>

    <menuitem id="menu_govaid_eligibility_verification" name="Eligibility Verification"
              parent="menu_govaid_relief"
              action="action_relief_application"
              sequence="15"/>

    <menuitem id="menu_govaid_relief_packages" name="Relief Packages"
              parent="menu_govaid_relief"
              action="action_relief_package"
              sequence="20"/>

    <!-- Logistics -->
    <menuitem id="menu_govaid_logistics" name="Logistics"
              parent="menu_govaid_root"
              sequence="40"/>

    <menuitem id="menu_govaid_dispatch_orders" name="Inventory Dispatch"
              parent="menu_govaid_logistics"
              action="action_dispatch_order"
              sequence="10"/>

    <!-- Assessments -->
    <menuitem id="menu_govaid_assessments" name="Assessments"
              parent="menu_govaid_root"
              sequence="50"/>

    <menuitem id="menu_govaid_damage_assessments" name="Damage Assessments"
              parent="menu_govaid_assessments"
              action="action_damage_assessment"
              sequence="10"/>

    <!-- Finance -->
    <menuitem id="menu_govaid_finance" name="Finance"
              parent="menu_govaid_root"
              sequence="60"/>

    <menuitem id="menu_govaid_payment_requests" name="Payment Requests"
              parent="menu_govaid_finance"
              action="action_payment_request"
              sequence="10"/>

    <record id="action_govaid_audit_trail" model="ir.actions.act_window">
        <field name="name">Audit Trail</field>
        <field name="res_model">mail.message</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('model', 'in', ['disaster.event', 'relief.application', 'damage.assessment', 'relief.package', 'payment.request', 'dispatch.order', 'g2p.beneficiary.demo', 'g2p.household.demo', 'g2p.program.enrollment.demo', 'g2p.entitlement.demo'])]</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No tracked messages yet</p>
            <p>Tracked messages from disaster recovery and OpenG2P-aligned demo records appear here.</p>
        </field>
    </record>

    <menuitem id="menu_govaid_audit_trail" name="Audit Trail"
              parent="menu_govaid_root"
              action="action_govaid_audit_trail"
              sequence="70"/>
</odoo>
