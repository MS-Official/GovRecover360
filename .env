# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL" #still the app is not hosted only using it through docker 

# PostGIS Spatial Database credentials
DB_PASSWORD="GovPassEnterpriseSecure2026!"
DB_DATABASE="govrecover360"
DB_USER="gov_operator"

# Asgardeo OIDC configuration values
ASGARDEO_ORGANIZATION="govrecover"
